---
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/posts/PostCard.astro";
import { getCollection } from "astro:content";

const published = (
  await getCollection("posts", ({ data }) => {
    return data.draft !== true;
  })
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
  <div class="mb-10 text-center">
    <h1 class="gradient-text text-4xl font-bold">tag.dev</h1>
    <p class="mt-2 text-base-content/60">
      My personal digital footprint. A collection of my thoughts, ideas, and
      experiments.
    </p>
  </div>

  <div class="space-y-6">
    {
      published.length === 0 && (
        <div class="rounded-2xl border border-base-300 bg-base-100 p-8 text-center">
          <p class="text-base-content/50">No posts yet. Stay tuned!</p>
        </div>
      )
    }

    {published.map((post) => <PostCard post={post} />)}
  </div>
</Layout>
